---
import type { ValidateProp } from '../types/validation.ts';
import type { InputStateProps } from '../types/directives.ts';
import { buildValidationAttrs, buildInputStateAttrs } from '../utils/build-directives.ts';

interface Props extends InputStateProps {
  /** Validation rules to apply */
  validate?: ValidateProp;
  /** Default text content of the textarea */
  value?: string;
  /** All standard HTML textarea attributes */
  [key: string]: any;
}

const { validate, errorClass, errorStyle, validClass, validStyle, value, ...rest } = Astro.props;

const validationAttrs = buildValidationAttrs(validate);
const stateAttrs = buildInputStateAttrs({ errorClass, errorStyle, validClass, validStyle });
---

<textarea {...validationAttrs} {...stateAttrs} {...rest}>{value ?? ''}</textarea>
