{
  "name": "astro-snipform",
  "version": "0.1.2",
  "description": "Typesafe Astro integration and components for SnipForm — directive-driven form backend for static sites",
  "keywords": [
    "astro",
    "astro-integration",
    "forms",
    "snipform",
    "static-sites",
    "validation"
  ],
  "license": "MIT",
  "workspaces": [
    "docs"
  ],
  "files": [
    "dist",
    "src/components",
    "src/types",
    "src/utils"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "components": [
        "./src/components/index.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./components": "./src/components/index.ts"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepare": "vp config",
    "docs:dev": "npm run dev --workspace=docs",
    "docs:build": "npm run build --workspace=docs",
    "docs:preview": "npm run preview --workspace=docs"
  },
  "devDependencies": {
    "astro": "^6.0.0",
    "typescript": "^5.7.0",
    "vite-plus": "latest"
  },
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.11.1"
}
